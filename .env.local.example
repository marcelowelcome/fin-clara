# .env.local.example — Clara Card Manager
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA commitar o .env.local no repositório.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ATENÇÃO: Service role key — apenas server-side. Nunca expor ao browser.
# Usada em API routes que precisam bypassar RLS (ex.: cron de notificações).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── E-mail (Resend) ───────────────────────────────────────────────────────────
# Crie uma conta em resend.com e gere uma API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_FROM_EMAIL=noreply@welcomeweddings.com.br
NOTIFY_FROM_NAME=Welcome Weddings

# ─── Aplicação ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção: https://clara.welcomeweddings.com.br

# ─── Upload ────────────────────────────────────────────────────────────────────
# Tamanho máximo do CSV em bytes (padrão: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760
